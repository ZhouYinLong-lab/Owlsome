[Unit]
Description=Owlsome Learning Backend
After=network.target

[Service]
Type=simple
WorkingDirectory=/data/workspace/projects/Owlsome/learning_platform/backend
EnvironmentFile=/data/workspace/projects/Owlsome/learning_platform/backend/.env
ExecStart=/data/workspace/projects/Owlsome/learning_platform/backend/.venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
