# Owlsome Learning frontend server deployment config
# Copy to .env.production before building for campus server:
#   cp .env.server.example .env.production

# Replace with your public reverse-proxy origin.
# For the current campus test route, Nginx Proxy Manager forwards /api to the backend.
VITE_API_BASE_URL=https://owlsome.lilystudio.space

# Comma-separated hostnames accepted by `npm run preview`.
VITE_PREVIEW_ALLOWED_HOSTS=owlsome.lilystudio.space
