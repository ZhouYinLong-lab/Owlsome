# Owlsome Learning server deployment config
# Copy this to .env before deploying on a campus network server:
#   cp .env.server.example .env

# Required: change this to a secret token for admin operations.
# Leave empty only for local single-user demo.
ADMIN_TOKEN=change-me-before-server-test

# Optional LLM provider. Core demo works without this.
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# Backward-compatible OpenRouter-style variables.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MODEL_NAME=deepseek/deepseek-v4-flash:free

# Optional BGE retrieval adapter. Keep off by default.
RETRIEVAL_PROVIDER=off
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_BASE_URL=
RERANKER_API_KEY=
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RETRIEVAL_TOP_K=8
RERANK_TOP_K=3
RETRIEVAL_TIMEOUT_SECONDS=30
