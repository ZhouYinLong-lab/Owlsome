# Optional LLM enhancement for Q&A. Current temporary recommendation is
# DeepSeek official OpenAI-compatible API. Legacy OPENROUTER_* names are still
# supported by the code for existing local .env files.
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# Optional retrieval enhancement. Keep `off` for the default offline demo.
RETRIEVAL_PROVIDER=off

# Embedding service. API key is optional for local/intranet deployments.
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=BAAI/bge-m3

# Optional reranker service. If unavailable, embedding order is kept.
RERANKER_BASE_URL=
RERANKER_API_KEY=
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

RETRIEVAL_TOP_K=8
RERANK_TOP_K=3
RETRIEVAL_TIMEOUT_SECONDS=30
